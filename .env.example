# ══════════════════════════════════════════════════
#  QueryBot — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores
#  No Railway: configure cada variável em Variables
# ══════════════════════════════════════════════════

# ── Zaia ──────────────────────────────────────────
# URL do webhook da sua IA na Zaia
ZAIA_WEBHOOK_URL=https://api.endless.zaia.app/webhook/SEU_ID_AQUI

# Token de autenticação: Zaia → /api/querybot.php
QUERYBOT_API_TOKEN=querybot123

# ── MySQL ─────────────────────────────────────────
# Localhost para dev; no Railway use os valores do plugin MySQL
DB_HOST=zephyr.proxy.rlwy.net
DB_PORT=56086
DB_NAME=railway
DB_USER=root
DB_PASS=KwSFgHqYVOnJXxtptIyfWlWBJJQJgFnd

# ── App ───────────────────────────────────────────
# Em produção mude para false
APP_DEBUG=false
APP_TIMEZONE=America/Sao_Paulo

# No Railway use /tmp/querybot.log (pasta com permissão de escrita)
# Em localhost pode usar ../logs/querybot.log
LOG_PATH=/tmp/querybot.log

# ── Chat UI ───────────────────────────────────────
BOT_NAME=QueryBot
BOT_SUBTITLE=Pergunte sobre o seu delivery
BOT_COLOR=#7c3aed
